  "keyFeatures": [
    "Customizable chat formats with MiniMessage support",
    "Per-group chat formatting for different permission levels",
    "Private messaging with cross-server support",
    "Player mentions with sound notifications",
    "Multi-server message broadcasting via Redis",
    "Chat cooldowns and spam prevention",
    "Message similarity detection",
    "Player ignore system with bypass permissions"
  ],
  "publicApiSurface": [
    "/broadcast <message> - Broadcast messages across servers",
    "/pm <username> <message> - Send private messages",
    "/r <message> - Reply to private messages",
    "/ignore <username> - Toggle ignoring players",
    "/clearchat [player] - Clear chat for all or specific player",
    "/fairychat reload - Reload configuration",
    "fairychat.command.broadcast - Permission for broadcast command",
    "fairychat.feature.minimessage - Permission to use MiniMessage formatting",
    "fairychat.bypass.cooldown - Permission to bypass chat cooldown",
    "fairychat.bypass.similarity - Permission to bypass similarity check",
    "PluginConfiguration - Main configuration class",
    "RedisCredentials - Redis connection configuration",
    "PrivateMessagingConfig - Private messaging settings",
    "BroadcastConfig - Broadcast settings",
    "MentionConfig - Mention system configuration"
  ]
